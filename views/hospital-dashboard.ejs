<!-- Hospital Dashboard -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hospital Dashboard - BloodLink</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/dashboard-ultra.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar Overlay for Mobile -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>
        
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-droplet"></i>
                <span>BloodLink</span>
            </div>
            <nav class="sidebar-nav">
                <a href="#" class="nav-item active" data-page="overview">
                    <i class="fas fa-home"></i> Overview
                </a>
                <a href="#" class="nav-item" data-page="emergency-request">
                    <i class="fas fa-ambulance"></i> Emergency Request
                </a>
                <a href="#" class="nav-item" data-page="create-request">
                    <i class="fas fa-plus"></i> Create Request
                </a>
                <a href="#" class="nav-item" data-page="manage-requests">
                    <i class="fas fa-list"></i> Manage Requests
                </a>
                <a href="#" class="nav-item" data-page="blood-inventory">
                    <i class="fas fa-warehouse"></i> Blood Inventory
                </a>
                <a href="#" class="nav-item" data-page="profile">
                    <i class="fas fa-building"></i> Hospital Profile
                </a>
                <a href="#" class="nav-item" data-page="analytics">
                    <i class="fas fa-chart-bar"></i> Analytics
                </a>
            </nav>
            <div class="sidebar-footer">
                <button id="logoutBtn" class="btn btn-logout">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <header class="dashboard-header">
                <button class="mobile-menu-btn" id="mobileSidebarBtn" aria-label="Open menu">
                    <i class="fas fa-bars"></i>
                </button>
                <h1 id="pageTitle">Welcome, Hospital!</h1>
                <div class="header-right">
                    <button class="notification-btn">
                        <i class="fas fa-bell"></i>
                        <span class="notification-badge" id="notificationCount">0</span>
                    </button>
                    <div class="user-profile">
                        <div class="user-avatar" id="userAvatar">H</div>
                        <span id="hospitalName">Loading...</span>
                    </div>
                </div>
            </header>

            <!-- Overview Page -->
            <section id="overview" class="page active">
                <div class="stats-grid">
                    <div class="stat-card">
                        <h3>Active Requests</h3>
                        <p class="stat-value" id="activeRequests">0</p>
                        <small>Pending</small>
                    </div>
                    <div class="stat-card">
                        <h3>Fulfilled Requests</h3>
                        <p class="stat-value" id="fulfilledRequests">0</p>
                        <small>Completed</small>
                    </div>
                    <div class="stat-card">
                        <h3>Matched Donors</h3>
                        <p class="stat-value" id="matchedDonors">0</p>
                        <small>Available</small>
                    </div>
                    <div class="stat-card">
                        <h3>Response Time</h3>
                        <p class="stat-value" id="responseTime">2.5 hrs</p>
                        <small>Average</small>
                    </div>
                </div>

                <!-- 3D Statistics Charts -->
                <div class="dashboard-card full-width">
                    <h2>Request Statistics</h2>
                    <div class="charts-container">
                        <div class="chart-3d">
                            <canvas id="requestsChart"></canvas>
                            <p>Request Status Distribution</p>
                        </div>
                        <div class="chart-3d">
                            <canvas id="bloodGroupChart"></canvas>
                            <p>Blood Group Requests</p>
                        </div>
                        <div class="chart-3d">
                            <canvas id="urgencyChart"></canvas>
                            <p>Urgency Levels</p>
                        </div>
                    </div>
                </div>

                <!-- Recent Requests -->
                <div class="dashboard-card">
                    <h2>Recent Requests</h2>
                    <div class="requests-list" id="recentRequests">
                        <p class="loading">Loading requests...</p>
                    </div>
                </div>
            </section>

            <!-- Create Request Page -->
            <section id="create-request" class="page">
                <div class="dashboard-card">
                    <h2>Create Blood Request</h2>
                    <form id="createRequestForm" class="form">
                        <div class="form-row">
                            <div class="form-group">
                                <label>Blood Group *</label>
                                <select name="bloodGroup" required>
                                    <option value="">Select blood group</option>
                                    <option value="O+">O+</option>
                                    <option value="O-">O-</option>
                                    <option value="A+">A+</option>
                                    <option value="A-">A-</option>
                                    <option value="B+">B+</option>
                                    <option value="B-">B-</option>
                                    <option value="AB+">AB+</option>
                                    <option value="AB-">AB-</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Units Needed *</label>
                                <input type="number" name="unitsNeeded" min="1" required placeholder="e.g., 2">
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Urgency Level *</label>
                                <select name="urgencyLevel" required>
                                    <option value="Normal">Normal</option>
                                    <option value="Urgent">Urgent</option>
                                    <option value="Critical">Critical</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Required By *</label>
                                <input type="datetime-local" name="requiredBy" required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Patient Name *</label>
                            <input type="text" name="patientName" required placeholder="Enter patient name">
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Patient Age</label>
                                <input type="number" name="patientAge" min="0" max="120">
                            </div>
                            <div class="form-group">
                                <label>Patient Gender</label>
                                <select name="patientGender">
                                    <option value="">Select</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Reason for Transfusion *</label>
                            <input type="text" name="reason" required placeholder="e.g., Emergency surgery">
                        </div>

                        <div class="form-group">
                            <label>Description</label>
                            <textarea name="description" rows="4" placeholder="Additional details..."></textarea>
                        </div>

                        <label class="checkbox">
                            <input type="checkbox" name="allowPublicContact">
                            <span>Allow public contact from donors</span>
                        </label>

                        <button type="submit" class="btn btn-primary">Create Request</button>
                    </form>
                </div>
            </section>

            <!-- Emergency Request Page -->
            <section id="emergency-request" class="page">
                <div class="emergency-page-header">
                    <div class="emergency-icon-large">🚨</div>
                    <h2>Create Emergency Blood Request</h2>
                    <p>Use this for critical, life-threatening situations. All eligible donors within 30km will be immediately notified.</p>
                </div>

                <div class="dashboard-card emergency-form-card">
                    <form id="emergencyRequestForm" class="form">
                        <div class="emergency-level-selector">
                            <label>Emergency Level</label>
                            <div class="level-options">
                                <label class="level-option">
                                    <input type="radio" name="emergencyLevel" value="Urgent" required>
                                    <span class="level-box urgent">
                                        <i class="fas fa-exclamation-circle"></i>
                                        <strong>Urgent</strong>
                                        <small>Within 2-4 hours</small>
                                    </span>
                                </label>
                                <label class="level-option">
                                    <input type="radio" name="emergencyLevel" value="Critical" checked>
                                    <span class="level-box critical">
                                        <i class="fas fa-exclamation-triangle"></i>
                                        <strong>Critical</strong>
                                        <small>Within 1 hour</small>
                                    </span>
                                </label>
                                <label class="level-option">
                                    <input type="radio" name="emergencyLevel" value="LifeThreatening">
                                    <span class="level-box life-threatening">
                                        <i class="fas fa-heartbeat"></i>
                                        <strong>Life Threatening</strong>
                                        <small>Immediate</small>
                                    </span>
                                </label>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Blood Group Required *</label>
                                <select name="bloodGroup" required>
                                    <option value="">Select blood group</option>
                                    <option value="O+">O+</option>
                                    <option value="O-">O- (Universal Donor)</option>
                                    <option value="A+">A+</option>
                                    <option value="A-">A-</option>
                                    <option value="B+">B+</option>
                                    <option value="B-">B-</option>
                                    <option value="AB+">AB+</option>
                                    <option value="AB-">AB-</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Units Needed *</label>
                                <input type="number" name="unitsNeeded" min="1" max="10" required placeholder="e.g., 3">
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Patient Name *</label>
                                <input type="text" name="patientName" required placeholder="Enter patient name">
                            </div>
                            <div class="form-group">
                                <label>Patient Age</label>
                                <input type="number" name="patientAge" min="0" max="120" placeholder="Age">
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Patient Condition *</label>
                            <select name="patientCondition" required>
                                <option value="">Select condition</option>
                                <option value="Accident">Accident / Trauma</option>
                                <option value="Surgery">Emergency Surgery</option>
                                <option value="Childbirth">Childbirth Complications</option>
                                <option value="Trauma">Severe Trauma</option>
                                <option value="Cancer">Cancer Treatment</option>
                                <option value="Other">Other Critical Condition</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Condition Details</label>
                            <textarea name="conditionDetails" rows="2" placeholder="Brief description of the patient's condition..."></textarea>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Required Within (minutes) *</label>
                                <select name="requiredWithin" required>
                                    <option value="30">30 minutes</option>
                                    <option value="60" selected>1 hour</option>
                                    <option value="120">2 hours</option>
                                    <option value="240">4 hours</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Emergency Contact Phone *</label>
                                <input type="tel" name="contactPhone" required placeholder="Phone number">
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Contact Person Name</label>
                            <input type="text" name="contactName" placeholder="Name of emergency contact">
                        </div>

                        <div class="form-group">
                            <label>Location/Address</label>
                            <input type="text" name="locationAddress" placeholder="Hospital address or specific location">
                        </div>

                        <div class="emergency-warning">
                            <i class="fas fa-info-circle"></i>
                            <p>This will immediately notify <strong>all eligible donors</strong> within 30km radius. Please ensure this is a genuine emergency.</p>
                        </div>

                        <button type="submit" class="btn btn-emergency btn-large">
                            <i class="fas fa-ambulance"></i> Send Emergency Alert
                        </button>
                    </form>
                </div>

                <!-- Active Emergencies -->
                <div class="dashboard-card">
                    <h2><i class="fas fa-list"></i> Your Active Emergencies</h2>
                    <div id="hospitalEmergenciesList">
                        <p class="loading">Loading...</p>
                    </div>
                </div>
            </section>

            <!-- Manage Requests Page -->
            <section id="manage-requests" class="page">
                <div class="filters">
                    <select id="statusFilter" class="filter-select">
                        <option value="">All Status</option>
                        <option value="open">Open</option>
                        <option value="emergency">Emergency</option>
                        <option value="fulfilled">Fulfilled</option>
                        <option value="closed">Closed</option>
                    </select>
                    <input type="text" id="searchRequests" placeholder="Search by patient name..." class="search-box">
                </div>

                <div class="requests-management" id="managedRequests">
                    <p class="loading">Loading requests...</p>
                </div>
            </section>

            <!-- Blood Inventory Page -->
            <section id="blood-inventory" class="page">
                <div class="dashboard-card">
                    <h2>Update Blood Inventory</h2>
                    <form id="inventoryForm" class="inventory-grid">
                        <div class="inventory-item">
                            <label>O+ (Units)</label>
                            <input type="number" name="O+" min="0" value="0">
                        </div>
                        <div class="inventory-item">
                            <label>O- (Units)</label>
                            <input type="number" name="O-" min="0" value="0">
                        </div>
                        <div class="inventory-item">
                            <label>A+ (Units)</label>
                            <input type="number" name="A+" min="0" value="0">
                        </div>
                        <div class="inventory-item">
                            <label>A- (Units)</label>
                            <input type="number" name="A-" min="0" value="0">
                        </div>
                        <div class="inventory-item">
                            <label>B+ (Units)</label>
                            <input type="number" name="B+" min="0" value="0">
                        </div>
                        <div class="inventory-item">
                            <label>B- (Units)</label>
                            <input type="number" name="B-" min="0" value="0">
                        </div>
                        <div class="inventory-item">
                            <label>AB+ (Units)</label>
                            <input type="number" name="AB+" min="0" value="0">
                        </div>
                        <div class="inventory-item">
                            <label>AB- (Units)</label>
                            <input type="number" name="AB-" min="0" value="0">
                        </div>
                    </form>
                    <button form="inventoryForm" class="btn btn-primary">Update Inventory</button>
                </div>

                <!-- Inventory Visualization -->
                <div class="dashboard-card">
                    <h2><i class="fas fa-vials" style="color: #e74c3c; margin-right: 10px;"></i>Current Stock Levels</h2>
                    <div class="inventory-chart">
                        <div class="inventory-chart-title">
                            <i class="fas fa-cube"></i>
                            <span>3D Interactive View</span>
                        </div>
                        <canvas id="inventoryChart"></canvas>
                        <div class="inventory-legend" id="inventoryLegend">
                            <!-- Legend will be populated dynamically -->
                        </div>
                    </div>
                </div>
            </section>

            <!-- Hospital Profile Page -->
            <section id="profile" class="page">
                <div class="dashboard-card">
                    <h2>Hospital Profile</h2>
                    <form id="profileForm" class="form">
                        <div class="form-group">
                            <label>Hospital Name *</label>
                            <input type="text" name="hospitalName" id="hospitalNameInput" required>
                        </div>
                        <div class="form-group">
                            <label>License Number *</label>
                            <input type="text" name="licenseNumber" id="licenseNumber" required>
                        </div>
                        <div class="form-group">
                            <label>Contact Person *</label>
                            <input type="text" name="contactPerson" id="contactPerson" required>
                        </div>
                        <div class="form-group">
                            <label>Contact Phone *</label>
                            <input type="tel" name="contactPhone" id="contactPhone" required>
                        </div>
                        <div class="form-group">
                            <label>Website</label>
                            <input type="url" name="website" id="website" placeholder="https://...">
                        </div>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </form>
                </div>
            </section>

            <!-- Analytics Page -->
            <section id="analytics" class="page">
                <div class="analytics-grid">
                    <div class="dashboard-card">
                        <h2>Performance Metrics</h2>
                        <div class="metric">
                            <span>Average Response Time</span>
                            <strong id="avgResponseTime">2.5 hours</strong>
                        </div>
                        <div class="metric">
                            <span>Request Fulfillment Rate</span>
                            <strong id="fulfillmentRate">92%</strong>
                        </div>
                        <div class="metric">
                            <span>Total Lives Saved</span>
                            <strong id="totalLivesSaved">1,250+</strong>
                        </div>
                    </div>

                    <div class="dashboard-card">
                        <h2>Blood Requests Trend</h2>
                        <canvas id="trendChart"></canvas>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- Request Detail Modal -->
    <div id="requestModal" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <div id="requestDetail"></div>
        </div>
    </div>

    <!-- Donors Modal -->
    <div id="donorsModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeDonorsModal()">&times;</span>
            <h2 style="color: #e74c3c; margin-bottom: 20px;"><i class="fas fa-users"></i> Interested Donors</h2>
            <div id="donorsList"></div>
        </div>
    </div>

    <script src="/js/auth-check.js"></script>
    <script src="/js/api.js"></script>
    <script src="/js/hospital-dashboard.js"></script>
    <script src="/js/3d-charts-ultra.js"></script>
</body>
</html>
