<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - BloodLink</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/auth-new.css">
</head>
<body>
    <div class="auth-wrapper">
        <!-- Left Side - Branding -->
        <div class="auth-left">
            <div class="auth-logo-section">
                <div class="logo-glow"></div>
                <div class="logo-circle">
                    <i class="fas fa-droplet"></i>
                </div>
                <h1>BloodLink</h1>
                <p>Connecting Donors with Lives</p>
            </div>

            <div class="features-list">
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <div class="feature-text">
                        <h3>Real-time Matching</h3>
                        <p>Instant blood donor match notifications</p>
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-map-location-dot"></i>
                    </div>
                    <div class="feature-text">
                        <h3>Near You</h3>
                        <p>Find donors within your location</p>
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-bell"></i>
                    </div>
                    <div class="feature-text">
                        <h3>Smart Alerts</h3>
                        <p>Never miss a donation request</p>
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-shield-heart"></i>
                    </div>
                    <div class="feature-text">
                        <h3>Secure & Safe</h3>
                        <p>Your privacy is our priority</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side - Login Form -->
        <div class="auth-right">
            <div class="form-container">
                <div class="form-header">
                    <h2>Welcome Back</h2>
                    <p>Login to your BloodLink account</p>
                </div>

                <form id="loginForm" class="modern-form">
                    <div class="form-field">
                        <label for="email">Email Address</label>
                        <div class="input-wrapper">
                            <i class="fas fa-envelope"></i>
                            <input 
                                type="email" 
                                id="email" 
                                name="email" 
                                placeholder="your@email.com"
                            >
                        </div>
                        <span class="field-error"></span>
                    </div>

                    <div class="form-field">
                        <label for="password">Password</label>
                        <div class="input-wrapper password-wrapper">
                            <i class="fas fa-lock"></i>
                            <input 
                                type="password" 
                                id="password" 
                                name="password" 
                                placeholder="••••••••"
                            >
                            <i class="fas fa-eye toggle-password" id="passwordToggle"></i>
                        </div>
                        <span class="field-error"></span>
                    </div>

                    <div class="form-options">
                        <label class="checkbox-label">
                            <input type="checkbox" name="remember" id="remember">
                            <span>Remember me</span>
                        </label>
                        <a href="#" class="forgot-link">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn-primary">Sign In</button>
                </form>

                <div class="form-divider">
                    <span>New to BloodLink?</span>
                </div>

                <a href="/auth/signup" class="btn-secondary">Create Account</a>

                <div class="form-footer">
                    <p>By signing in, you agree to our <a href="#">Terms</a> & <a href="#">Privacy Policy</a></p>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-overlay hidden" id="successModal">
        <div class="modal-content">
            <i class="fas fa-check-circle"></i>
            <h3>Login Successful!</h3>
            <p>Redirecting...</p>
        </div>
    </div>

    <script src="/js/auth.js"></script>
</body>
</html>
