<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - BloodLink</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/auth-new.css">
</head>
<body>
    <div class="auth-wrapper signup-wrapper">
        <!-- Left Side - Info -->
        <div class="auth-left">
            <div class="auth-logo-section">
                <div class="logo-glow"></div>
                <div class="logo-circle">
                    <i class="fas fa-droplet"></i>
                </div>
                <h1>BloodLink</h1>
                <p>Save Lives. Make a Difference.</p>
            </div>

            <div class="signup-info">
                <h3>Why Join BloodLink?</h3>
                <ul>
                    <li><i class="fas fa-heart"></i> Be a hero in your community</li>
                    <li><i class="fas fa-users"></i> Connect with thousands of donors</li>
                    <li><i class="fas fa-gauge-high"></i> Track your impact</li>
                    <li><i class="fas fa-lock"></i> Secure & verified platform</li>
                </ul>
                <p class="info-text">Join hospitals and donors making a real difference in saving lives.</p>
            </div>
        </div>

        <!-- Right Side - Signup Form -->
        <div class="auth-right">
            <div class="form-container">
                <div class="form-header">
                    <h2>Create Your Account</h2>
                    <p>Join thousands saving lives</p>
                </div>

                <div class="role-tabs">
                    <button type="button" class="role-tab active" data-role="donor">
                        <i class="fas fa-heart"></i>
                        <span>I'm a Donor</span>
                    </button>
                    <button type="button" class="role-tab" data-role="hospital">
                        <i class="fas fa-hospital"></i>
                        <span>I'm a Hospital</span>
                    </button>
                </div>

                <form id="signupForm" class="modern-form">
                    <input type="hidden" id="userRole" name="userRole" value="donor">

                    <div class="form-field">
                        <label for="name">Full Name</label>
                        <div class="input-wrapper">
                            <i class="fas fa-user"></i>
                            <input 
                                type="text" 
                                id="name" 
                                name="name" 
                                placeholder="John Doe"
                            >
                        </div>
                        <span class="field-error"></span>
                    </div>

                    <div class="form-field">
                        <label for="email">Email Address</label>
                        <div class="input-wrapper">
                            <i class="fas fa-envelope"></i>
                            <input 
                                type="email" 
                                id="email" 
                                name="email" 
                                placeholder="your@email.com"
                            >
                        </div>
                        <span class="field-error"></span>
                    </div>

                    <div class="form-field">
                        <label for="phone">Phone Number</label>
                        <div class="input-wrapper">
                            <i class="fas fa-phone"></i>
                            <input 
                                type="tel" 
                                id="phone" 
                                name="phone" 
                                placeholder="+1 (555) 000-0000"
                            >
                        </div>
                        <span class="field-error"></span>
                    </div>

                    <!-- Donor Specific Fields -->
                    <div id="donorFields" class="conditional-fields">
                        <div class="form-field">
                            <label for="bloodGroup">Blood Group</label>
                            <div class="input-wrapper">
                                <i class="fas fa-droplet"></i>
                                <select id="bloodGroup" name="bloodGroup">
                                    <option value="">Select blood group</option>
                                    <option value="O+">O+</option>
                                    <option value="O-">O-</option>
                                    <option value="A+">A+</option>
                                    <option value="A-">A-</option>
                                    <option value="B+">B+</option>
                                    <option value="B-">B-</option>
                                    <option value="AB+">AB+</option>
                                    <option value="AB-">AB-</option>
                                </select>
                            </div>
                            <span class="field-error"></span>
                        </div>
                        <div class="form-field">
                            <label for="age">Age</label>
                            <div class="input-wrapper">
                                <i class="fas fa-calendar"></i>
                                <input 
                                    type="number" 
                                    id="age" 
                                    name="age" 
                                    placeholder="18" 
                                    min="18" 
                                    max="65"
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Hospital Specific Fields -->
                    <div id="hospitalFields" class="conditional-fields" style="display:none;">
                        <div class="form-field">
                            <label for="hospitalName">Hospital Name</label>
                            <div class="input-wrapper">
                                <i class="fas fa-hospital"></i>
                                <input 
                                    type="text" 
                                    id="hospitalName" 
                                    name="hospitalName" 
                                    placeholder="Hospital Name"
                                >
                            </div>
                            <span class="field-error"></span>
                        </div>
                        <div class="form-field">
                            <label for="licenseNumber">License Number</label>
                            <div class="input-wrapper">
                                <i class="fas fa-id-card"></i>
                                <input 
                                    type="text" 
                                    id="licenseNumber" 
                                    name="licenseNumber" 
                                    placeholder="License Number"
                                >
                            </div>
                            <span class="field-error"></span>
                        </div>
                    </div>

                    <div class="form-field">
                        <label for="address">Address</label>
                        <div class="input-wrapper">
                            <i class="fas fa-location-dot"></i>
                            <input 
                                type="text" 
                                id="address" 
                                name="address" 
                                placeholder="Street Address"
                            >
                        </div>
                        <span class="field-error"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-field">
                            <label for="city">City</label>
                            <div class="input-wrapper">
                                <i class="fas fa-city"></i>
                                <input 
                                    type="text" 
                                    id="city" 
                                    name="city" 
                                    placeholder="City"
                                >
                            </div>
                            <span class="field-error"></span>
                        </div>
                        <div class="form-field">
                            <label for="state">State</label>
                            <div class="input-wrapper">
                                <i class="fas fa-map"></i>
                                <input 
                                    type="text" 
                                    id="state" 
                                    name="state" 
                                    placeholder="State"
                                >
                            </div>
                            <span class="field-error"></span>
                        </div>
                    </div>

                    <div class="form-field">
                        <label for="pincode">Pincode</label>
                        <div class="input-wrapper">
                            <i class="fas fa-map-pin"></i>
                            <input 
                                type="text" 
                                id="pincode" 
                                name="pincode" 
                                placeholder="123456"
                                maxlength="6"
                            >
                        </div>
                        <span class="field-error"></span>
                    </div>

                    <div class="form-field">
                        <label for="password">Password</label>
                        <div class="input-wrapper password-wrapper">
                            <i class="fas fa-lock"></i>
                            <input 
                                type="password" 
                                id="password" 
                                name="password" 
                                placeholder="••••••••"
                            >
                            <i class="fas fa-eye toggle-password"></i>
                        </div>
                        <span class="field-error"></span>
                    </div>

                    <div class="form-field">
                        <label for="confirmPassword">Confirm Password</label>
                        <div class="input-wrapper password-wrapper">
                            <i class="fas fa-lock"></i>
                            <input 
                                type="password" 
                                id="confirmPassword" 
                                name="confirmPassword" 
                                placeholder="••••••••"
                            >
                            <i class="fas fa-eye toggle-password"></i>
                        </div>
                        <span class="field-error"></span>
                    </div>

                    <label class="checkbox-label">
                        <input type="checkbox" id="terms" name="terms">
                        <span>I agree to <a href="#">Terms & Conditions</a> and <a href="#">Privacy Policy</a></span>
                    </label>

                    <button type="submit" class="btn-primary">Create Account</button>
                </form>

                <div class="form-divider">
                    <span>Already have an account?</span>
                </div>

                <a href="/auth/login" class="btn-secondary">Sign In</a>

                <div class="form-footer">
                    <p>By signing up, you agree to our Terms & Privacy Policy</p>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/auth.js"></script>
</body>
</html>
